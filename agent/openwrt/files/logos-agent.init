#!/bin/sh /etc/rc.common
# procd service for logos-agent: starts the management channel when the node
# is enrolled; procd restarts it on crash (PRD F1: survives reboots).

START=95
STOP=10
USE_PROCD=1

PROG=/usr/bin/logos-agent

start_service() {
	# Runs whether or not the node is enrolled: without state the agent
	# serves the first-run setup page (F2, http://<router>:8484) until
	# someone enrolls it; with state it opens the management channel.
	procd_open_instance
	procd_set_param command "$PROG" run
	procd_set_param respawn 3600 5 0   # retry forever, 5s apart
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger logos
}
