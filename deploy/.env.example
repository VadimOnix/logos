# Copy to .env and edit before `docker compose up`.
POSTGRES_PASSWORD=change-me-to-something-long
LOGOS_ADMIN_EMAIL=admin@example.com
LOGOS_ADMIN_PASSWORD=change-me-min-10-chars
# Public DNS name (or IP) agents will dial for the mTLS channel, e.g.
# logos.example.com — baked into the agent listener's certificate.
LOGOS_AGENT_HOST=localhost,127.0.0.1
# Full agent endpoint URL if it differs from wss://<first host>:8443
#LOGOS_AGENT_ENDPOINT=wss://logos.example.com:8443

# --- Production reverse proxy (deploy/docker-compose.prod.yml) ---
# Public domain for the panel/API. Caddy obtains a Let's Encrypt cert for it
# automatically. Set LOGOS_AGENT_HOST to the same name so agents dial it.
#LOGOS_PANEL_DOMAIN=logos.example.com

# --- Node-offline alerts (F11) — enabled when a sink is configured ---
# Generic JSON webhook: POST {"source":"logos","subject":...,"text":...}
#LOGOS_ALERT_WEBHOOK_URL=https://hooks.example.com/T000/B000/XXXX
# How long a node must be silent before the offline alert fires (default 3m).
#LOGOS_ALERT_OFFLINE_AFTER=3m
# Root-filesystem usage % that triggers a low-flash alert (default 90; 0 off).
#LOGOS_ALERT_DISK_PCT=90
# Memory usage % that triggers a memory-pressure alert (default 0 = off —
# routers legitimately run hot on RAM; enable if you know your fleet).
#LOGOS_ALERT_MEM_PCT=95
# Telegram delivery: create a bot with @BotFather, add it to a chat/channel,
# set both values (chat id is numeric, or @channelname for public channels).
#LOGOS_ALERT_TELEGRAM_TOKEN=123456:ABC-DEF...
#LOGOS_ALERT_TELEGRAM_CHAT=-1001234567890
# Email alerts via SMTP (STARTTLS + AUTH when the server supports them).
#LOGOS_SMTP_ADDR=smtp.example.com:587
#LOGOS_SMTP_FROM=logos@example.com
#LOGOS_SMTP_TO=ops@example.com,admin@example.com
#LOGOS_SMTP_USER=logos@example.com
#LOGOS_SMTP_PASSWORD=app-password
